import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner x=new Scanner(System.in);
        int count=0;
        int n=x.nextInt();
         for (int i=1;i<=n;i++)
         {
             if (n%i==0){
                 count++;
             }
         }
         System.out.println(count);
    }
}
