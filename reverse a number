import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int N;
        int reverse=0;
        Scanner x=new Scanner(System.in);
         N=x.nextInt();
        while(N>0)
        {
            int d=N%10;
                reverse=reverse*10+d;
            N=N/10;
        }
            System.out.print(reverse);
        }
    }
