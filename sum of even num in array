import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
       Scanner x=new Scanner(System.in);
        int n=x.nextInt();
        int arr[]=new int[50];
        int sum=0;
        for(int i=0;i<n;i++){
            arr[i]=x.nextInt();
            if(arr[i]%2==0)
            sum=sum+arr[i];
        }
            System.out.print(sum);
        
    }
}
        
