import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner x= new Scanner(System.in);
        String str=x.next();
        for(int i=0;i<str.length();i++){
          char ch=str.charAt(i);
          if(ch =='a'){
            continue;
          }
          System.out.print(ch);
        }
        
    }
}
