import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner x=new Scanner(System.in);
        int N=x.nextInt();
         int fact=1;
            for(int i=1;i<=N;i++){
                fact=fact*i;
            }
        System.out.println(fact);
        
    }
}
    
