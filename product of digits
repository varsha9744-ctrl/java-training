import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner x = new Scanner(System.in);
        int n = x.nextInt();
        int product=1;
        while(n>0){
          int digit=n%10;
          product=product*digit;
          n=n/10;
        }
        System.out.println(product);
          
        
    }
}
