import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner x = new Scanner(System.in);
        int n = x.nextInt();
        int sum=0;
      for(int i=1;i<=n;i++){
         if(i%5==0){
           sum=sum+i;
         }
          }
        System.out.println(sum);
          
        
    }
}
