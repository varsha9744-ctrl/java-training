import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner x = new Scanner(System.in);
        int oddSum=0;
        int evenSum=0;
        int n = x.nextInt();

        for (int i = 1; i <= n; i++) {
            if (i % 2 == 0) {
                evenSum=evenSum+i;
            }
            else{
              oddSum=oddSum=i;
            }
        }
        System.out.println(evenSum);
        System.out.println(oddSum);
        System.out.println(evenSum + oddSum);
    }
}
