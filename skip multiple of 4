import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner x= new Scanner(System.in);
        int n=x.nextInt();
        for(int i=1;i<=n;i++){
          
          if(i%4==0){
            continue;
          }
          System.out.println(i);
        }
        
    }
}
