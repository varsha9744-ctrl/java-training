import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner x=new Scanner(System.in);
        int N=x.nextInt();
         int sum=0;
            for(int i=1;i<=N;i++){
                sum=sum+i;
            }
        System.out.println(sum);
        
    }
}
