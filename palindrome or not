import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {

        Scanner x = new Scanner(System.in);

        int N = x.nextInt();
        int original = N;
        int reverse = 0;

        while (N > 0) {
            int digit = N % 10;
            reverse = reverse*10+digit;
            N = N / 10;
        }

        if (original == reverse) {
            System.out.print("Palindrome");
        } else {
            System.out.print("Not Palindrome");
        }
    }
}
